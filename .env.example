# Supabase — create a project at https://supabase.com and copy Project URL + anon key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: use in server routes for privileged operations. The leads API falls back to the anon key
# if unset (ensure RLS allows insert for `anon`, as in `supabase/migrations/001_initial.sql`).
SUPABASE_SERVICE_ROLE_KEY=
