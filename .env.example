# Prisma — Vercel+Supabase integration injects this automatically:
POSTGRES_PRISMA_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# If you only have DATABASE_URL (e.g. older docs), set POSTGRES_PRISMA_URL to the same value.

# Supabase Auth (integration usually sets these exact names):
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Optional: service role for admin scripts only — never expose to browser
# SUPABASE_SERVICE_ROLE_KEY=

# Cron / Vercel: protect /api/cron/sync
CRON_SECRET="generate-a-long-random-string"

# Optional: OpenAI for grounded LLM layer on strategist
# OPENAI_API_KEY=

# Seed: optional email to attach mock data; otherwise first user or built-in demo user is used
# SEED_USER_EMAIL="you@company.com"

# Demo login (cookie-based, no Supabase). Set to "false" to hide demo entry points.
# DEMO_AUTH_ENABLED="true"
